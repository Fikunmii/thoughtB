# ─────────────────────────────────────────────────────────────────────────────
# Thought Biography — Frontend Environment Variables
# Save this file as frontend/.env.local
# Vite reads it automatically. Never commit it (it's in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend URL ───────────────────────────────────────────────────────────────
# Development: your local FastAPI server
VITE_API_URL=http://localhost:8000

# Production: set this to your Railway URL in Netlify's environment settings
# VITE_API_URL=https://your-app.up.railway.app
