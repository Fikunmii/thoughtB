SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Production Gmail setup:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=hello@thoughtbiography.com
# SMTP_PASSWORD=your-16-char-gmail-app-password
# EMAIL_FROM=hello@thoughtbiography.com

# ── Admin ─────────────────────────────────────────────────────────────────────
# Protects the POST /digest/send-now endpoint
ADMIN_KEY=devkey
